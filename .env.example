# Copy this file to .env.local and fill in your values
# These must also be set in Vercel → Settings → Environment Variables

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Local API options:
# 1) Preferred: leave VITE_API_URL unset and use Vite proxy (/api -> VITE_API_PROXY_TARGET)
# 2) Alternative: set VITE_API_URL directly to backend API URL
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_API_URL=
